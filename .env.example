# Copy to .env and fill in your values — never commit .env

JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_jira_api_token
# AI provider — set one (or both) of the keys below.
# AI_PROVIDER is auto-detected from whichever key is present; set explicitly to force a provider.
# AI_MODEL overrides the default model for the selected provider.
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
# AI_PROVIDER=anthropic
# AI_MODEL=claude-opus-4-8   # defaults: claude-opus-4-8 (anthropic) / gpt-4o (openai)

# App authentication (HTTP Basic) — optional.
# Set BOTH to require a username + password on every request (the browser shows
# a native login prompt). Leave unset for open access (local-dev default).
# In production, set these as environment variables.
# CADENCE_AUTH_USER=team
# CADENCE_AUTH_PASSWORD=change-me
