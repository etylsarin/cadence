# Non-secret app configuration — safe to commit
# Secrets go in .env (gitignored) or environment variables

# Jira project keys used across all tools
PROJECTS=MLP,SUP,ADM

# Sync pipeline
SYNC_ISSUE_TYPES=Story,Spike,Bug,Task,Epic
SYNC_START_DATE=2025-01-01

# Tool registry — one tool per line, format: id|Name|description
# description: shown on the homepage card (source of truth — no frontend copy).
# Homepage order follows this list. Comment out or remove a line to hide a tool.
TOOLS[]=sync|Sync Now|Manage the Jira mirror pipeline, trigger syncs and view history.
TOOLS[]=ask|Ask|Chat with your Jira data, delivery, velocity, defects and more.
TOOLS[]=release-notes|Release Notes|Generate AI-powered release notes from Jira fix versions.
TOOLS[]=sprint-summary|Sprint Summary|Summarise sprint progress and outcomes for stakeholders.

# CORS allowed origins — comma-separated. Restrict this in production.
# Production: same-origin requests don't need CORS, but list the URL for completeness.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8765,http://localhost:8000
